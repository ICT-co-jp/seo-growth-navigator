# ictgrowthhacker-mcp 環境設定サンプル
#
# このファイルを `.env` にコピーして、自分の環境に合わせて値を埋めてください。
# 秘密情報（client_secret の中身 / OAuth リフレッシュトークン）は .env には書きません。
# 別途 keyring（Windows資格情報マネージャー）に保存します（README参照）。
#
# .env はこのフォルダ直下に置きます: mcp_server/.env

# ---- 必須 -----------------------------------------------------------------

# GA4 プロパティID (例: 123456789)
# Google Analytics の管理 > プロパティ設定 で確認できる数字
GA4_PROPERTY_ID=

# Search Console のサイトURL
# ドメインプロパティの場合は `sc-domain:example.com` 形式
# URLプレフィックスプロパティの場合は `https://example.com/` 形式
GSC_SITE_URL=sc-domain:example.com

# ---- 任意 -----------------------------------------------------------------

# OAuth クライアントを発行したGCPプロジェクトID
# 設定すると Google API のクォータがそのプロジェクトに紐づく
# 未設定でも動作するが、推奨。
ICTGROWTHHACKER_QUOTA_PROJECT=

# keyring に保存する際のサービス名。複数の対象サイトを切り替えて使うときに変える。
# 未設定なら既定値 `ictgrowthhacker-mcp` が使われる。
# ICTGROWTHHACKER_KEYRING_SERVICE=ictgrowthhacker-mcp

# デバッグログを出す場合は 1
# ICTGROWTHHACKER_MCP_DEBUG=0
